                        ],
                        "fill-opacity": 0.3
                    },
                    "outline_style": {
                        "line-color": "#555555",
                        "line-width": 0.3,
                        "line-opacity": 0.5
                    },
                    "tooltip_fields": ["SWAP_Common", "SWAP_Scientific", "Taxonomic_Group"],
                    "legend_type": "categorical",
                    "legend_classes": [
                        { "label": "Amphibians", "color": "#66C2A5" },
                        { "label": "Birds", "color": "#FC8D62" },
                        { "label": "Fish", "color": "#8DA0CB" },
                        { "label": "Mammals", "color": "#E78AC3" },
                        { "label": "Reptiles", "color": "#A6D854" }
                    ]
                }
            ]
        },
        {
            "collection_id": "swap-2025-noaa-esu-dps",
            "collection_url": "https://s3-west.nrp-nautilus.io/public-cdfw/swap-2025/noaa-esu-dps/stac-collection.json",
            "assets": [
                {
                    "id": "noaa-esu-dps-pmtiles",
                    "display_name": "Salmonid ESU / DPS (NOAA)",
                    "group": "Marine & Anadromous",
                    "visible": false,
                    "default_style": {
                        "fill-color": [
                            "match",
                            ["get", "Class"],
                            "Accessible", "#2166AC",
                            "Accessible - Likely Extirpated", "#F4A582",
                            "Accessible-Likely Extirpated", "#F4A582",
                            "Naturally Blocked", "#B2ABD2",
                            "Historical Watershed: Anthropogenically Blocked", "#B2182B",
                            "#BDBDBD"
                        ],
                        "fill-opacity": 0.5
                    },
                    "outline_style": {
                        "line-color": "#333333",
                        "line-width": 0.4,
                        "line-opacity": 0.6
                    },
                    "tooltip_fields": ["ESU_DPS", "ESU_or_DPS", "Class", "Status"],
                    "legend_type": "categorical",
                    "legend_classes": [
                        { "label": "Accessible", "color": "#2166AC" },
                        { "label": "Accessible — likely extirpated", "color": "#F4A582" },
                        { "label": "Naturally blocked", "color": "#B2ABD2" },
                        { "label": "Anthropogenically blocked", "color": "#B2182B" }
                    ]
