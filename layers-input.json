    "mcp_url": "https://dev-duckdb-mcp.nrp-nautilus.io/mcp",
    "auto_approve": true,
    "geocoder": {
        "provider": "nominatim",
        "search_box": true
    },
    "geolocate": {
        "button": true,
        "agent_tool": true
    },
    "sidebar": {
        "enabled": true,
        "chat_title": "Chat"
    },
    "view": {
        "center": [
            -98,
            39
        ],
        "zoom": 4
    },
    "welcome": {
        "message": "Hi! I explore State Wildlife Action Plans across California, Nevada, and Missouri — three states that structure conservation very differently. Each state's layers are kept separate (e.g. \"CA SGCN species\" vs \"Nevada species distributions\" vs \"Missouri COAs\") so you can see and compare their approaches. National context layers (protected areas, land cover, administrative boundaries, social vulnerability) are available too. Try asking:",
        "examples": [
            "Show California's SWAP provinces and Nevada's key habitats.",
            "How do California, Nevada, and Missouri each define their conservation geographies?",
            "Turn on Missouri's Conservation Opportunity Areas.",
            "Compare the number of SGCN species by taxonomic group in California vs Nevada."
        ]
    },
    "links": {
        "github": "https://github.com/boettiger-lab/swap",
        "docs": "/docs.html",
        "carbon": true
    },
